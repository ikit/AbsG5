NODE_ENV=development
API_PORT=5010
WS_PORT=5011
AUTH_SESSION_DURATION_MS=3600000
AUTH_SESSION_SALT=jwtSecretSalt
CORS_ORIGIN=http://localhost:8080

DB_TYPE_DEFAULT=postgres
DB_HOST_DEFAULT=localhost
DB_PORT_DEFAULT=5432
DB_USER_DEFAULT=postgres
DB_PASSWORD_DEFAULT=postgres
DB_NAME_DEFAULT=postgres

PATH_FILES=/var/absg5/files
URL_FILES=https://host.com/api/files/
URL_CLIENT=https://host.com/

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# DEBUG: Force l'édition courante des AGPA (laisser vide pour calculer automatiquement)
# Utile pour tester les fonctionnalités d'anciennes éditions
# Exemple: AGPA_FORCE_EDITION=2024
AGPA_FORCE_EDITION=

# pCloud integration (Europe API)
PCLOUD_ACCESS_TOKEN=
PCLOUD_UNSORTED_FOLDER_ID=
PCLOUD_SORTED_FOLDER_ID=
